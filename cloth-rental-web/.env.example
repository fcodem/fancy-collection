# PostgreSQL — use Vercel Postgres or Neon (https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Session signing (generate: openssl rand -base64 32)
SESSION_SECRET="change-me-to-a-long-random-string"

# Optional: Vercel Blob for dress photos (replaces local static/uploads)
BLOB_READ_WRITE_TOKEN=""

# Default owner password on first seed (change after deploy)
OWNER_DEFAULT_PASSWORD="admin123"
