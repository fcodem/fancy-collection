{
  "name": "fancy-collection-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-dev-ready.mjs",
    "dev": "node --max-old-space-size=4096 node_modules/next/dist/bin/next dev -p 3000",
    "dev:open": "node --max-old-space-size=4096 node_modules/next/dist/bin/next dev -p 3000",
    "build": "prisma generate && next build",
    "build:vercel": "node scripts/vercel-build.mjs",
    "start": "next start",
    "start:prod": "next start -H 0.0.0.0",
    "preview": "npm run build && npm run start:prod",
    "lint": "next lint",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/prisma-postinstall.mjs",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset-owner": "tsx scripts/reset-owner.ts",
    "copy-assets": "node scripts/copy-assets.mjs",
    "db:studio": "prisma studio",
    "db:backup": "tsx scripts/save-backup.ts",
    "db:migrate-sqlite": "python ../scripts/migrate_sqlite_to_postgres.py",
    "reindex:inventory": "tsx scripts/reindex-all-inventory.ts",
    "dress:audit": "tsx scripts/dress-audit.ts",
    "dress:reindex": "tsx scripts/dress-reindex.ts",
    "dress:repair": "tsx scripts/dress-reindex.ts --repair",
    "dress:deploy-check": "tsx scripts/dress-deploy-check.ts",
    "dress:worker": "tsx scripts/dress-worker.ts",
    "dress:fingerprint-backfill": "tsx scripts/dress-fingerprint-backfill.ts",
    "dress:reindex-v4": "tsx scripts/dress-reindex-v4.ts",
    "dress:forensic": "tsx scripts/ai-queue-forensic.ts",
    "dress:forensic-crossview": "tsx scripts/forensic-cross-view-bridal.ts",
    "dress:eval": "tsx scripts/dress-eval.ts",
    "dress:seed-onion-pairs": "tsx scripts/seed-onion-negative-pair.ts",
    "deployment:audit": "tsx scripts/deployment-audit.ts",
    "cron:use-hobby": "node scripts/switch-vercel-crons.mjs hobby",
    "cron:use-pro": "node scripts/switch-vercel-crons.mjs pro"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@prisma/client": "^6.5.0",
    "@sentry/nextjs": "^10.59.0",
    "@sparticuz/chromium": "^131.0.1",
    "@types/qrcode": "^1.5.6",
    "@vercel/blob": "^0.27.0",
    "@xenova/transformers": "^2.17.2",
    "ably": "^2.23.0",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.4.8",
    "docx": "^9.7.1",
    "html5-qrcode": "^2.3.8",
    "iron-session": "^8.0.4",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "next": "^15.2.4",
    "openai": "^6.45.0",
    "puppeteer": "^24.4.0",
    "puppeteer-core": "^24.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.33.5",
    "twemoji": "^14.0.2",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@prisma/nextjs-monorepo-workaround-plugin": "^6.19.3",
    "@tailwindcss/postcss": "^4.0.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
