generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("staff")
  staffId      Int?     @map("staff_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  staff              Staff?              @relation(fields: [staffId], references: [id])
  loginRequests      StaffLoginRequest[] @relation("LoginUser")
  resolvedRequests   StaffLoginRequest[] @relation("ResolvedBy")
  sessions           UserSession[]       @relation("SessionUser")
  endedSessions      UserSession[]       @relation("EndedBy")

  @@map("users")
}

model StaffLoginRequest {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  token        String    @unique
  status       String    @default("pending")
  requestedAt  DateTime  @default(now()) @map("requested_at")
  resolvedAt   DateTime? @map("resolved_at")
  resolvedById Int?      @map("resolved_by_id")

  user       User  @relation("LoginUser", fields: [userId], references: [id])
  resolvedBy User? @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([token])
  @@map("staff_login_requests")
}

model UserSession {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  sessionId  String    @unique @map("session_id")
  active     Boolean   @default(true)
  loginAt    DateTime  @default(now()) @map("login_at")
  lastSeen   DateTime  @default(now()) @map("last_seen")
  endedAt    DateTime? @map("ended_at")
  endedById  Int?      @map("ended_by_id")

  user     User  @relation("SessionUser", fields: [userId], references: [id])
  endedBy  User? @relation("EndedBy", fields: [endedById], references: [id])

  @@index([sessionId])
  @@map("user_sessions")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  address   String?
  idProof   String?  @map("id_proof")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  rentals Rental[]

  @@index([phone])
  @@map("customers")
}

model ClothingItem {
  id              Int      @id @default(autoincrement())
  name            String
  sku             String   @unique
  category        String
  size            String?
  color           String?
  dailyRate       Float    @default(0) @map("daily_rate")
  deposit         Float    @default(0)
  status          String   @default("available")
  itemType        String   @default("clothing") @map("item_type")
  photo           String?
  conditionNotes  String?  @map("condition_notes")
  createdAt       DateTime @default(now()) @map("created_at")
  subCategory     String?  @map("sub_category")
  hasNecklace     Boolean  @default(false) @map("has_necklace")
  hasEarrings     Boolean  @default(false) @map("has_earrings")
  hasTeeka        Boolean  @default(false) @map("has_teeka")
  hasPasa         Boolean  @default(false) @map("has_pasa")
  aiFingerprint   String?  @map("ai_fingerprint")
  aiIndexedAt     DateTime? @map("ai_indexed_at")
  siglipEmbedding Json?    @map("siglip_embedding")
  siglipIndexedAt DateTime? @map("siglip_indexed_at")
  identificationIndex Json? @map("identification_index")
  identificationIndexedAt DateTime? @map("identification_indexed_at")
  recognitionImage        String?   @map("recognition_image")
  recognitionFingerprint  Json?     @map("recognition_fingerprint")

  rentalItems         RentalItem[]
  referencePhotos     ClothingItemReferencePhoto[]
  aiProfile           InventoryAiProfile?
  dressCheckerCorrectionsCorrect   DressCheckerCorrection[] @relation("DressCheckerCorrectionCorrect")
  dressCheckerCorrectionsPredicted DressCheckerCorrection[] @relation("DressCheckerCorrectionPredicted")
  bookings            Booking[]          @relation("LegacyBookingItem")
  bookingItems        BookingItem[]
  prospectLeadItems   ProspectLeadItem[]
  jewellerySelections BookingJewellery[]

  @@index([status])
  @@index([category, status])
  @@map("clothing_items")
}

model ClothingItemReferencePhoto {
  id                  Int       @id @default(autoincrement())
  itemId              Int       @map("item_id")
  photo               String
  label               String?
  sortOrder           Int       @default(0) @map("sort_order")
  contentHash         String?   @map("content_hash")
  identificationIndex Json?     @map("identification_index")
  indexedAt           DateTime? @map("indexed_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  item ClothingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("clothing_item_reference_photos")
}

model Rental {
  id               Int       @id @default(autoincrement())
  rentalNumber     String    @unique @map("rental_number")
  customerId       Int       @map("customer_id")
  startDate        DateTime  @map("start_date")
  endDate          DateTime  @map("end_date")
  actualReturnDate DateTime? @map("actual_return_date")
  status           String    @default("active")
  subtotal         Float     @default(0)
  depositTotal     Float     @default(0) @map("deposit_total")
  lateFee          Float     @default(0) @map("late_fee")
  damageFee        Float     @default(0) @map("damage_fee")
  discount         Float     @default(0)
  totalAmount      Float     @default(0) @map("total_amount")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  customer Customer     @relation(fields: [customerId], references: [id])
  items    RentalItem[]
  invoices Invoice[]

  @@index([customerId])
  @@index([status, endDate])
  @@map("rentals")
}

model RentalItem {
  id        Int   @id @default(autoincrement())
  rentalId  Int   @map("rental_id")
  itemId    Int?     @map("item_id")
  dailyRate Float @map("daily_rate")
  deposit   Float @default(0)

  rental Rental       @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  item   ClothingItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@map("rental_items")
}

model Invoice {
  id            Int       @id @default(autoincrement())
  invoiceNumber String    @unique @map("invoice_number")
  rentalId      Int       @map("rental_id")
  issueDate     DateTime  @default(now()) @map("issue_date")
  dueDate       DateTime? @map("due_date")
  subtotal      Float     @default(0)
  taxRate       Float     @default(0) @map("tax_rate")
  taxAmount     Float     @default(0) @map("tax_amount")
  total         Float     @default(0)
  amountPaid    Float     @default(0) @map("amount_paid")
  status        String    @default("unpaid")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  rental   Rental    @relation(fields: [rentalId], references: [id])
  payments Payment[]

  @@map("invoices")
}

model Payment {
  id        Int      @id @default(autoincrement())
  invoiceId Int      @map("invoice_id")
  amount    Float
  method    String   @default("cash")
  reference String?
  notes     String?
  paidAt    DateTime @default(now()) @map("paid_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Booking {
  id                 Int       @id @default(autoincrement())
  bookingNumber      String    @unique @map("booking_number")
  monthlySerial      Int       @default(0) @map("monthly_serial")
  customerName       String    @map("customer_name")
  customerAddress    String    @map("customer_address")
  contact1           String    @map("contact_1")
  whatsappNo         String?   @map("whatsapp_no")
  deliveryDate       DateTime  @map("delivery_date")
  deliveryTime       String    @map("delivery_time")
  returnDate         DateTime  @map("return_date")
  returnTime         String    @map("return_time")
  venue              String?
  securityDeposit    Float     @default(0) @map("security_deposit")
  totalPrice         Float     @default(0) @map("total_price")
  totalAdvance       Float     @default(0) @map("total_advance")
  totalRemaining     Float     @default(0) @map("total_remaining")
  advancePaymentMode String    @default("cash") @map("advance_payment_mode")
  remainingPaymentMode String?  @map("remaining_payment_mode")
  securityPaymentMode String?  @map("security_payment_mode")
  commonNotes        String?   @map("common_notes")
  staffNames         String?   @map("staff_names")
  status             String    @default("booked")
  createdAt          DateTime  @default(now()) @map("created_at")
  deliveryNotes      String?   @map("delivery_notes")
  remainingCollected Float     @default(0) @map("remaining_collected")
  securityCollected  Float     @default(0) @map("security_collected")
  deliveredAt        DateTime? @map("delivered_at")
  returnedAt         DateTime? @map("returned_at")
  incompleteNotes    String?   @map("incomplete_notes")
  incompletePhoto    String?   @map("incomplete_photo")
  idPhoto1           String?   @map("id_photo_1")
  idPhoto2           String?   @map("id_photo_2")
  securityHeld       Float     @default(0) @map("security_held")
  itemId             Int?      @map("item_id")
  dressName          String?   @map("dress_name")
  price              Float     @default(0)
  advance            Float     @default(0)
  remaining          Float     @default(0)
  notes              String?
  contact2           String?   @map("contact_2")
  qrToken            String?   @unique @map("qr_token")
  refundAmount       Float     @default(0) @map("refund_amount")
  refundedAt         DateTime? @map("refunded_at")
  postponedAt        DateTime? @map("postponed_at")
  publicBookingId    String?   @unique @map("public_booking_id")
  qrCodeUrl          String?   @map("qr_code_url")
  whatsappStatus     String?   @map("whatsapp_status")
  whatsappSentAt     DateTime? @map("whatsapp_sent_at")
  whatsappError      String?   @map("whatsapp_error")
  lateReminderSentAt DateTime? @map("late_reminder_sent_at")

  legacyItem            ClothingItem?          @relation("LegacyBookingItem", fields: [itemId], references: [id], onDelete: SetNull)
  bookingItems          BookingItem[]
  orders                BookingOrder[]
  selectedJewellery     BookingJewellery[]
  whatsAppJobs          WhatsAppJob[]
  whatsAppMessages      WhatsAppMessage[]
  whatsAppConversations WhatsAppConversation[]

  @@index([deliveryDate, status])
  @@index([returnDate, status])
  @@index([status, deliveryDate])
  @@index([status, monthlySerial])
  @@index([monthlySerial])
  @@index([customerName])
  @@index([contact1])
  @@index([whatsappNo])
  @@index([createdAt])
  @@index([customerName, deliveryDate])
  @@map("bookings")
}

model BookingItem {
  id            Int     @id @default(autoincrement())
  bookingId     Int     @map("booking_id")
  itemId        Int?    @map("item_id")
  dressName     String  @map("dress_name")
  category      String?
  price         Float   @default(0)
  advance       Float   @default(0)
  remaining     Float   @default(0)
  size          String?
  notes         String?
  preparedBy    String? @map("prepared_by")
  checkedBy     String? @map("checked_by")
  isPackedReady Boolean @default(false) @map("is_packed_ready")
  packingNote   String? @map("packing_note")
  isDelivered   Boolean @default(false) @map("is_delivered")
  deliveredAt   DateTime? @map("delivered_at")
  itemRemainingCollected Float @default(0) @map("item_remaining_collected")
  itemSecurityCollected  Float @default(0) @map("item_security_collected")
  itemDeliveryNotes      String? @map("item_delivery_notes")
  isReturned             Boolean @default(false) @map("is_returned")
  isIncompleteReturn     Boolean @default(false) @map("is_incomplete_return")
  itemIncompleteNotes    String? @map("item_incomplete_notes")
  itemIncompletePhoto    String? @map("item_incomplete_photo")
  itemSecurityHeld       Float   @default(0) @map("item_security_held")
  deliverySlipNotifiedAt DateTime? @map("delivery_slip_notified_at")
  returnSlipNotifiedAt   DateTime? @map("return_slip_notified_at")

  booking Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  item    ClothingItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([dressName])
  @@index([category])
  @@index([bookingId])
  @@index([bookingId, dressName])
  @@map("booking_items")
}

model BookingOrder {
  id                 Int       @id @default(autoincrement())
  bookingId          Int       @map("booking_id")
  description        String
  cost               Float     @default(0)
  advance            Float     @default(0)
  balance            Float     @default(0)
  photo              String?
  deliveryDate       DateTime  @map("delivery_date")
  deliveryTime       String    @map("delivery_time")
  advancePaymentMode String?   @map("advance_payment_mode")
  balanceCollected   Float     @default(0) @map("balance_collected")
  collectedAt        DateTime? @map("collected_at")
  collectPaymentMode String?   @map("collect_payment_mode")
  status             String    @default("active")
  readyAt            DateTime? @map("ready_at")
  cancelledAt        DateTime? @map("cancelled_at")
  refundAmount       Float     @default(0) @map("refund_amount")
  reminderSentAt     DateTime? @map("reminder_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([deliveryDate])
  @@index([status, deliveryDate])
  @@map("booking_orders")
}

model BookingJewellery {
  id        Int      @id @default(autoincrement())
  bookingId Int      @map("booking_id")
  itemId    Int?     @map("item_id")
  name      String
  category  String?
  photo     String?
  source    String   @default("manual")
  note          String?
  pickNecklace  Boolean  @default(false) @map("pick_necklace")
  pickEarrings  Boolean  @default(false) @map("pick_earrings")
  pickTeeka     Boolean  @default(false) @map("pick_teeka")
  pickPasa      Boolean  @default(false) @map("pick_pasa")
  status        String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  item    ClothingItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([itemId])
  @@map("booking_jewellery")
}

model CustomCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  group     String   @default("other")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("custom_categories")
}

model HiddenCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("hidden_categories")
}

model CustomSubCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("custom_sub_categories")
}

model Staff {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  users         User[]
  attendances   StaffAttendance[]
  salaryEntries SalaryLedgerEntry[]

  @@map("staff")
}

model StaffAttendance {
  id      Int      @id @default(autoincrement())
  staffId Int      @map("staff_id")
  date    DateTime
  status  String   @default("present")

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@map("staff_attendance")
}

model SalaryLedgerEntry {
  id        Int      @id @default(autoincrement())
  staffId   Int      @map("staff_id")
  date      DateTime
  amount    Float    @default(0)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([staffId, date])
  @@map("salary_ledger")
}

model LedgerExpense {
  id          Int      @id @default(autoincrement())
  date        DateTime
  category    String
  amount      Float    @default(0)
  paymentMode String   @default("cash") @map("payment_mode")
  notes       String?
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("ledger_expenses")
}

model Supplier {
  id             Int      @id @default(autoincrement())
  name           String
  phone          String?
  address        String?
  gstNo          String?  @map("gst_no")
  accountDetails String?  @map("account_details")
  createdAt      DateTime @default(now()) @map("created_at")

  purchases SupplierPurchase[]

  @@map("suppliers")
}

model SupplierPurchase {
  id              Int      @id @default(autoincrement())
  supplierId      Int      @map("supplier_id")
  itemDescription String   @map("item_description")
  category        String?
  amount          Float    @default(0)
  gstAmount       Float    @default(0) @map("gst_amount")
  gstPercent      Float    @default(0) @map("gst_percent")
  transactionType String   @default("purchase") @map("transaction_type")
  date            DateTime @default(now())
  notes           String?

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_purchases")
}

model ProspectLead {
  id              Int       @id @default(autoincrement())
  customerName    String    @map("customer_name")
  customerAddress String?   @map("customer_address")
  contact1        String?   @map("contact_1")
  whatsappNo      String?   @map("whatsapp_no")
  venue           String?
  notes           String?
  staffNames      String?   @map("staff_names")
  deliveryDate    DateTime  @map("delivery_date")
  deliveryTime    String?   @map("delivery_time")
  returnDate      DateTime  @map("return_date")
  returnTime      String?   @map("return_time")
  lastReminderAt  DateTime? @map("last_reminder_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  items ProspectLeadItem[]

  @@map("prospect_leads")
}

model ProspectLeadItem {
  id             Int   @id @default(autoincrement())
  prospectLeadId Int   @map("prospect_lead_id")
  itemId         Int   @map("item_id")
  rent           Float @default(0)

  prospectLead ProspectLead @relation(fields: [prospectLeadId], references: [id], onDelete: Cascade)
  item         ClothingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("prospect_lead_items")
}

model ShopEnquiry {
  id              Int      @id @default(autoincrement())
  customerName    String   @map("customer_name")
  customerAddress String?  @map("customer_address")
  contact1        String?  @map("contact_1")
  whatsappNo      String?  @map("whatsapp_no")
  enquiryNotes    String?  @map("enquiry_notes")
  staffNames      String?  @map("staff_names")
  visitDate       DateTime @map("visit_date")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("shop_enquiries")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  username   String
  action     String
  entity     String
  entityId   Int?     @map("entity_id")
  label      String?
  dataBefore String?  @map("data_before")
  dataAfter  String?  @map("data_after")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([username])
  @@index([createdAt])
  @@map("activity_logs")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ip        String
  success   Boolean  @default(false)
  username  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ip, createdAt])
  @@map("login_attempts")
}

model WhatsAppJob {
  id            Int       @id @default(autoincrement())
  jobType       String    @map("job_type")
  bookingId     Int?      @map("booking_id")
  payload       Json?
  scheduledAt   DateTime  @map("scheduled_at")
  status        String    @default("pending")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3) @map("max_attempts")
  lastAttemptAt DateTime? @map("last_attempt_at")
  completedAt   DateTime? @map("completed_at")
  failedReason  String?   @map("failed_reason")
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String?   @map("created_by")
  booking       Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([bookingId])
  @@map("whatsapp_jobs")
}

model WhatsAppConversation {
  id             Int       @id @default(autoincrement())
  customerPhone  String    @unique @map("customer_phone")
  customerName   String    @map("customer_name")
  bookingId      Int?      @map("booking_id")
  isWindowOpen   Boolean   @default(false) @map("is_window_open")
  windowOpenedAt DateTime? @map("window_opened_at")
  lastMessageAt  DateTime? @map("last_message_at")
  unreadCount    Int       @default(0) @map("unread_count")
  createdAt      DateTime  @default(now()) @map("created_at")

  booking  Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  messages WhatsAppMessage[]

  @@index([bookingId])
  @@index([lastMessageAt])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id             Int                   @id @default(autoincrement())
  conversationId Int?                  @map("conversation_id")
  bookingId      Int?                  @map("booking_id")
  phone          String?
  direction      String                @default("outbound")
  messageType    String                @map("message_type")
  body           String?
  mediaUrl       String?               @map("media_url")
  filename       String?
  metaMessageId  String?               @map("meta_message_id")
  isAutomated    Boolean               @default(false) @map("is_automated")
  status         String                @default("sent")
  deliveryStatus String?               @map("delivery_status")
  deliveredAt    DateTime?             @map("delivered_at")
  readAt         DateTime?             @map("read_at")
  receivedAt     DateTime?             @map("received_at")
  error          String?
  createdAt      DateTime              @default(now()) @map("created_at")

  booking      Booking?              @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  conversation WhatsAppConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([metaMessageId])
  @@map("whatsapp_messages")
}

model WhatsAppBroadcast {
  id           Int       @id @default(autoincrement())
  name         String
  templateName String    @map("template_name")
  status       String    @default("pending")
  totalCount   Int       @default(0) @map("total_count")
  sentCount    Int       @default(0) @map("sent_count")
  failedCount  Int       @default(0) @map("failed_count")
  createdBy    String?   @map("created_by")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("whatsapp_broadcasts")
}

model DressCheckerCorrection {
  id                Int      @id @default(autoincrement())
  correctItemId     Int      @map("correct_item_id")
  predictedItemId   Int?     @map("predicted_item_id")
  predictedSku      String?  @map("predicted_sku")
  confidence        Float?
  hybridScore       Float?   @map("hybrid_score")
  featureComparison Json?    @map("feature_comparison")
  feedbackType      String   @default("positive") @map("feedback_type")
  rejectedItemId    Int?     @map("rejected_item_id")
  uploadedPhoto     String   @map("uploaded_photo")
  correctedBy       String?  @map("corrected_by")
  searchId          String?  @map("search_id")
  createdAt         DateTime @default(now()) @map("created_at")

  correctItem   ClothingItem  @relation("DressCheckerCorrectionCorrect", fields: [correctItemId], references: [id], onDelete: Cascade)
  predictedItem ClothingItem? @relation("DressCheckerCorrectionPredicted", fields: [predictedItemId], references: [id], onDelete: SetNull)

  @@index([correctItemId])
  @@index([createdAt])
  @@map("dress_checker_corrections")
}

/// Enterprise AI Inventory Profile — semantic metadata, versioned embeddings, health.
model InventoryAiProfile {
  itemId Int @id @map("item_id")

  status          String    @default("none")
  error           String?
  currentVersion  Int       @default(0) @map("current_version")
  pipelineVersion String    @default("1") @map("pipeline_version")
  indexedAt       DateTime? @map("indexed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  description         String? @db.Text
  searchText          String? @db.Text @map("search_text")
  colourAnalysis      Json?   @map("colour_analysis")
  garmentAttributes   Json?   @map("garment_attributes")
  jewelleryAttributes Json?   @map("jewellery_attributes")
  qualityScores       Json?   @map("quality_scores")
  duplicateFingerprint Json?  @map("duplicate_fingerprint")
  healthScore         Float?  @map("health_score")
  healthIssues        Json?   @map("health_issues")

  recognitionImage       String?   @map("recognition_image")
  recognitionFingerprint Json?     @map("recognition_fingerprint")
  recognitionVersion     Int       @default(0) @map("recognition_version")
  modelVersion           String?   @map("model_version")
  qualityScore           Float?    @map("quality_score")
  lastProcessed          DateTime? @map("last_processed")

  item      ClothingItem                @relation(fields: [itemId], references: [id], onDelete: Cascade)
  versions  InventoryAiProfileVersion[]
  tags      InventoryAiProfileTag[]
  override  InventoryAiProfileOverride?
  logs      InventoryAiProfileLog[]

  @@index([status])
  @@index([healthScore])
  @@map("inventory_ai_profiles")
}

/// Append-only version history — never overwrite previous embedding/metadata snapshots.
model InventoryAiProfileVersion {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  version   Int
  createdAt DateTime @default(now()) @map("created_at")

  embeddingModel        String? @map("embedding_model")
  embeddingModelVersion String? @map("embedding_model_version")
  visionModel             String? @map("vision_model")
  pipelineVersion         String? @map("pipeline_version")

  embeddings           Json?
  featureFingerprint   Json?   @map("feature_fingerprint")
  duplicateFingerprint Json?   @map("duplicate_fingerprint")
  colourAnalysis       Json?   @map("colour_analysis")
  garmentAttributes    Json?   @map("garment_attributes")
  jewelleryAttributes  Json?   @map("jewellery_attributes")
  qualityScores        Json?   @map("quality_scores")
  description          String? @db.Text
  tagsSnapshot         Json?   @map("tags_snapshot")
  sourceImages         Json?   @map("source_images")

  profile InventoryAiProfile @relation(fields: [itemId], references: [itemId], onDelete: Cascade)

  @@unique([itemId, version])
  @@index([itemId])
  @@map("inventory_ai_profile_versions")
}

model InventoryAiProfileTag {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  tag       String
  source    String   @default("ai")
  createdAt DateTime @default(now()) @map("created_at")

  profile InventoryAiProfile @relation(fields: [itemId], references: [itemId], onDelete: Cascade)

  @@unique([itemId, tag, source])
  @@index([tag])
  @@index([itemId])
  @@map("inventory_ai_profile_tags")
}

/// Manual administrator overrides — AI originals preserved in versions.
model InventoryAiProfileOverride {
  itemId Int @id @map("item_id")

  description         String? @db.Text
  tags                Json?
  colourAnalysis      Json?   @map("colour_analysis")
  garmentAttributes   Json?   @map("garment_attributes")
  jewelleryAttributes Json?   @map("jewellery_attributes")
  category            String?
  subCategory         String? @map("sub_category")
  qualityNotes        String? @db.Text @map("quality_notes")
  updatedAt           DateTime @updatedAt @map("updated_at")
  updatedBy           String?  @map("updated_by")

  profile InventoryAiProfile @relation(fields: [itemId], references: [itemId], onDelete: Cascade)

  @@map("inventory_ai_profile_overrides")
}

model InventoryAiProfileLog {
  id           Int      @id @default(autoincrement())
  itemId       Int      @map("item_id")
  event        String
  message      String?
  version      Int?
  modelVersion String?  @map("model_version")
  durationMs   Int?     @map("duration_ms")
  retryCount   Int?     @map("retry_count")
  createdAt    DateTime @default(now()) @map("created_at")

  profile InventoryAiProfile @relation(fields: [itemId], references: [itemId], onDelete: Cascade)

  @@index([itemId])
  @@index([createdAt])
  @@index([event])
  @@map("inventory_ai_profile_logs")
}
