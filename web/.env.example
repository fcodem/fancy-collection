# PostgreSQL (required — Vercel serverless cannot use SQLite file URLs)
# Production: Vercel Postgres, Neon, or Supabase
DATABASE_URL="postgresql://user:password@host:5432/cloth_rental?sslmode=require"

# Local dev: use PostgreSQL (Neon free dev branch, or local Docker):
#   docker run -d --name fc-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=cloth_rental postgres:16
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cloth_rental"
# Then: npm run db:push && npm run db:seed
# Migrate legacy SQLite data: npm run db:migrate-sqlite (requires fancynew/cloth_rental.db)

# Session encryption (generate: openssl rand -base64 32)
SESSION_SECRET="change-this-to-a-long-random-string-at-least-32-chars"

# Optional: Vercel Blob for item photo uploads in production
BLOB_READ_WRITE_TOKEN=""

# App URL (set automatically on Vercel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Realtime (Vercel serverless) ---
# polling = refresh every 12s (default, no extra services)
# ably = instant cross-instance pub/sub (requires ABLY_API_KEY + npm package ably)
# sse = legacy EventEmitter SSE (local single-process dev only)
NEXT_PUBLIC_REALTIME_MODE="polling"
NEXT_PUBLIC_REALTIME_POLL_MS="12000"
# Server publish mode (defaults to NEXT_PUBLIC_REALTIME_MODE)
# REALTIME_MODE="polling"
# ABLY_API_KEY=""  # required when mode=ably — from https://ably.com

# --- Sentry (optional — leave blank to disable; zero runtime cost when unset) ---
# Create a free project at https://sentry.io
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Optional: upload source maps in CI/production builds
SENTRY_AUTH_TOKEN=""

# --- Vercel Cron (return reminders at 9:00 AM Asia/Kolkata) ---
# Vercel sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="generate-a-long-random-string"

# --- Twilio SMS (return reminders — used only if AiSensy return campaign is not set) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- AiSensy WhatsApp (https://www.app.aisensy.com) ---
# 1. In AiSensy: Manage → API Key → copy key
# 2. Create Live API Campaigns for each message type (Campaigns → +Launch → API Campaign)
# 3. Match template variables to the param order documented below
AISENSY_API_KEY=""
AISENSY_PROJECT_ID="652795c3f2c43a0e0d7a5d3c"
AISENSY_SOURCE="fancy-collection-web"
# Live API campaign names (must match AiSensy dashboard exactly)
AISENSY_CAMPAIGN_BOOKING="fc_booking_confirmation"
AISENSY_CAMPAIGN_PROSPECT="fc_prospect_reminder"
AISENSY_CAMPAIGN_RETURN="fc_return_reminder"
# Optional fallback campaign if type-specific name is not set
AISENSY_CAMPAIGN_DEFAULT=""
# Set true to auto-send booking confirmation via AiSensy when a new booking is saved
AISENSY_AUTO_SEND_BOOKING="false"
#
# Template variable mapping (create matching WhatsApp templates in AiSensy):
# Booking: {{1}} name, {{2}} serial, {{3}} delivery, {{4}} return, {{5}} dresses,
#          {{6}} total, {{7}} advance, {{8}} balance, {{9}} venue, {{10}} bill URL
# Prospect: {{1}} name, {{2}} dresses, {{3}} delivery, {{4}} return, {{5}} status, {{6}} unavailable
# Return: {{1}} name, {{2}} serial, {{3}} return date, {{4}} return time
