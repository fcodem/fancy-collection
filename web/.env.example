# PostgreSQL (required — Vercel serverless cannot use SQLite file URLs)
# Production: Vercel Postgres, Neon, or Supabase
DATABASE_URL="postgresql://user:password@host:5432/cloth_rental?sslmode=require"
# Vercel serverless: add ?pgbouncer=true&connection_limit=1 to DATABASE_URL
# when using a pooler (Neon, Supabase, or Railway all provide one):
# DATABASE_URL="postgresql://user:pass@pooler-host:5432/db?sslmode=require&pgbouncer=true&connection_limit=1"
# Also set DIRECT_URL for migrations (non-pooled):
# DIRECT_URL="postgresql://user:pass@direct-host:5432/db?sslmode=require"

# Local dev: use PostgreSQL (Neon free dev branch, or local Docker):
#   docker run -d --name fc-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=cloth_rental postgres:16
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cloth_rental"
# Then: npm run db:push && npm run db:seed
# Migrate legacy SQLite data: npm run db:migrate-sqlite (requires fancynew/cloth_rental.db)

# Session encryption (generate: openssl rand -base64 32)
SESSION_SECRET="change-this-to-a-long-random-string-at-least-32-chars"

# Optional: Vercel Blob for item photo uploads in production
BLOB_READ_WRITE_TOKEN=""

# App URL (set automatically on Vercel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp slip PDF generation — path to Chrome/Edge (local dev). On Vercel, @sparticuz/chromium is used.
# CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"

# --- Realtime (multi-staff sync) ---
# polling = every browser polls every NEXT_PUBLIC_REALTIME_POLL_MS ms (default, no extra setup)
# ably    = instant push updates, eliminates all polling — RECOMMENDED for production
#           1. Create a free account at https://ably.com (free tier: 6M messages/month)
#           2. Copy your API key from the Ably dashboard
#           3. Set the vars below and redeploy
NEXT_PUBLIC_REALTIME_MODE="polling"
NEXT_PUBLIC_REALTIME_POLL_MS="12000"
REALTIME_MODE="polling"
# ABLY_API_KEY=""   # paste your Ably API key here, then change both REALTIME_MODE values to "ably"

# --- Sentry (optional — leave blank to disable; zero runtime cost when unset) ---
# Create a free project at https://sentry.io
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Optional: upload source maps in CI/production builds
SENTRY_AUTH_TOKEN=""

# --- Vercel Cron ---
# Used for cron auth and internal slip PDF rendering (WhatsApp attachments).
# Vercel sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="generate-a-long-random-string"
# Optional override for slip PDF only (defaults to CRON_SECRET):
# PDF_RENDER_SECRET=""

# ─── META WHATSAPP CLOUD API ──────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_secret_string_here
WHATSAPP_API_VERSION=v19.0
# Pause all automated slip/receipt WhatsApp sends while testing (true | false)
# WHATSAPP_RECEIPTS_DISABLED=true
META_APP_ID=1937024637016610

# ─── WHATSAPP MESSAGE TEMPLATES ───────────────────────────────────
# Create these templates in Meta Business Manager
# They must be APPROVED by Meta before use
WA_TEMPLATE_BOOKING_BILL=booking_confirmation
WA_TEMPLATE_BOOKING_REMINDER=return_reminder
WA_TEMPLATE_POSTPONEMENT=booking_postponed

# ─── BUSINESS INFO ────────────────────────────────────────────────
BUSINESS_NAME=Your Business Name Here
BUSINESS_PHONE=91XXXXXXXXXX
BUSINESS_ADDRESS=Your shop address here

# ─── DEPRECATED AISENSY (replaced by Meta WhatsApp) ───────────────
# AISENSY_API_KEY=
# AISENSY_CAMPAIGN_BOOKING=
# AISENSY_CAMPAIGN_BOOKING_QR=
# AISENSY_CAMPAIGN_BOOKING_IMAGE=

