# PostgreSQL — use Vercel Postgres or Neon (https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Session signing (generate: openssl rand -base64 32)
SESSION_SECRET="change-me-to-a-long-random-string"

# Public catalogue / inventory photos (Vercel Blob — public store)
BLOB_READ_WRITE_TOKEN=

# Private booking media: ID proofs, order photos, incomplete returns (separate private Blob store)
ID_PROOF_BLOB_READ_WRITE_TOKEN=
# Legacy alias (same private store; prefer ID_PROOF_BLOB_READ_WRITE_TOKEN above):
# ID_PROOF_READ_WRITE_TOKEN=

# Default owner password on first seed (change after deploy)
OWNER_DEFAULT_PASSWORD="admin123"
