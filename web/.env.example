# PostgreSQL (required — Vercel serverless cannot use SQLite file URLs)
# Prefer Supabase Transaction pooler for DATABASE_URL (port 6543):
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=2&connect_timeout=10&pool_timeout=15"
# Session pooler for DIRECT_URL (port 5432 on pooler host — NOT db.*.supabase.co on Vercel):
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
#
# If you used Vercel ↔ Supabase integration, it may set POSTGRES_URL / POSTGRES_PRISMA_URL /
# POSTGRES_URL_NON_POOLING instead. The app maps those automatically, but setting
# DATABASE_URL + DIRECT_URL explicitly is clearest.
#
# Local dev: use PostgreSQL (Neon free dev branch, or local Docker):
#   docker run -d --name fc-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=cloth_rental postgres:16
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cloth_rental"
# Then: npm run db:push && npm run db:seed
# Migrate legacy SQLite data: npm run db:migrate-sqlite (requires fancynew/cloth_rental.db)

# Session encryption (generate: openssl rand -base64 32)
SESSION_SECRET="change-this-to-a-long-random-string-at-least-32-chars"

# Public catalogue / inventory photos (Vercel Blob store — access: public)
BLOB_READ_WRITE_TOKEN=""

# Private customer ID-proof photos ONLY (separate Vercel Blob store — access: private).
# Never reuse BLOB_READ_WRITE_TOKEN for ID proofs in Production or Preview.
ID_PROOF_BLOB_READ_WRITE_TOKEN=""

# App URL (set automatically on Vercel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp slip PDF generation — path to Chrome/Edge (local dev). On Vercel, @sparticuz/chromium is used.
# CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"

# --- Realtime (multi-staff sync) ---
# polling = every browser polls every NEXT_PUBLIC_REALTIME_POLL_MS ms (default, no extra setup)
# ably    = instant push updates, eliminates all polling — RECOMMENDED for production
#           1. Create a free account at https://ably.com (free tier: 6M messages/month)
#           2. Copy your API key from the Ably dashboard
#           3. Set the vars below and redeploy
NEXT_PUBLIC_REALTIME_MODE="polling"
NEXT_PUBLIC_REALTIME_POLL_MS="60000"
REALTIME_MODE="polling"
# ABLY_API_KEY=""   # paste your Ably API key here, then change both REALTIME_MODE values to "ably"

# --- Sentry (optional — leave blank to disable; zero runtime cost when unset) ---
# Create a free project at https://sentry.io
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Optional: upload source maps in CI/production builds
SENTRY_AUTH_TOKEN=""

# --- Vercel Cron ---
# Used for cron auth and internal slip PDF rendering (WhatsApp attachments).
# Durable AI indexing worker (Postgres job queue — no Redis required)
# AI_JOB_WORKER_INTERVAL_MS=5000

# Optional override for slip PDF only (defaults to CRON_SECRET):
# PDF_RENDER_SECRET=""

# ─── AI IMAGE ENHANCEMENT (Pipeline 2) — PAUSED BY DEFAULT ────────
# Auto dress enhancement is OFF in code (enhancementFeatureFlags.ts).
# Inventory upload saves the original photo only and still collects metadata.
# Enhancement code is kept for future use. To force-enable locally:
# AI_AUTO_IMAGE_ENHANCEMENT=1
# AI_AUTO_IMAGE_ENHANCEMENT=0

# ─── AI INVENTORY STUDIO (Mannequin catalogue images) ─────────────
# Required for professional mannequin showcase / booking-slip images.
# Uses OpenAI gpt-image-1 image edits (same quality as ChatGPT image generation).
# OPENAI_API_KEY=sk-...
# Optional model override (default gpt-image-1):
# OPENAI_IMAGE_MODEL=gpt-image-1

# ─── AI DRESS CHECKER — OPENAI VISION PRECISION ───────────────────
# REQUIRED for reliable Dress Checker identification precision.
# OPENAI_API_KEY=sk-...
# Optional overrides:
# DRESS_CHECKER_VLM=0            # set to 0 to force-disable the OpenAI vision precision stage
# DRESS_CHECKER_VLM_MODEL=gpt-4.1-mini
# DRESS_CHECKER_OPENAI_ENABLED=1
# DRESS_CHECKER_MAX_OPENAI_CALLS_PER_RUN=0
# DRESS_CHECKER_MAX_OPENAI_CALLS_PER_SEARCH=1
# DRESS_CHECKER_OPENAI_VERIFY_MIN_SCORE=70
# DRESS_CHECKER_OPENAI_VERIFY_MAX_SCORE=92
# DRESS_CHECKER_ANN_RECALL_K=100
# AI_SETTINGS_SECRET=change-this-for-encrypted-ai-settings

# ─── META WHATSAPP CLOUD API ──────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_secret_string_here
WHATSAPP_API_VERSION=v19.0
# Pause all automated slip/receipt WhatsApp sends while testing (true | false)
# WHATSAPP_RECEIPTS_DISABLED=true
META_APP_ID=1036638175496482
# Optional — needed to upload sample PDF when creating DOCUMENT templates via API:
# META_APP_SECRET=your_meta_app_secret

# ─── WHATSAPP AUTO-REPLY CHATBOT ──────────────────────────────────
# The bot auto-replies to inbound customer messages until a team member
# replies in that chat (then it stays silent for that conversation).
# Turn the whole bot off with: WHATSAPP_BOT_DISABLED=true
# WHATSAPP_BOT_DISABLED=false
# Optional details used in auto-replies:
# WHATSAPP_BOT_SHOP_NAME=Fancy Collection by Renu Agarwal
# WHATSAPP_BOT_ADDRESS=Your shop address here
# WHATSAPP_BOT_HOURS=10:00 AM – 9:00 PM (all days)
# WHATSAPP_BOT_PHONE=+91XXXXXXXXXX

# Public HTTPS base for WhatsApp template URL buttons (ngrok or production).
# Required to auto-create the link-style booking_confirmation template.
# WHATSAPP_PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.dev

# ─── WHATSAPP MESSAGE TEMPLATES ───────────────────────────────────
