# They must be APPROVED by Meta before cold sends (outside 24h window).
# booking_confirmation = UTILITY template (DOCUMENT header or URL button).
WA_TEMPLATE_BOOKING_BILL=booking_slip_v3
WA_TEMPLATE_BOOKING_BILL_LANG=en
WA_TEMPLATE_DELIVERY_SLIP=delivery_slip_v5
WA_TEMPLATE_RETURN_SLIP=return_slip_v3
WA_TEMPLATE_INCOMPLETE_SLIP=incomplete_return_v3
WA_TEMPLATE_BOOKING_REMINDER=return_due_v3
WA_TEMPLATE_POSTPONEMENT=booking_dates_v3
WA_TEMPLATE_POSTPONEMENT_HELD=booking_held_v3
WA_TEMPLATE_MARKETING_FESTIVE=festive_offer
WA_TEMPLATE_MARKETING_COLLECTION=new_collection
WA_TEMPLATE_SLIPS_LANG=en

# ─── BUSINESS INFO ────────────────────────────────────────────────
BUSINESS_NAME=Your Business Name Here
BUSINESS_PHONE=91XXXXXXXXXX
BUSINESS_ADDRESS=Your shop address here

